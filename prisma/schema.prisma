generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN @map("admin")
  KASIR @map("kasir")
}

enum ShiftStatus {
  OPEN   @map("open")
  CLOSED @map("closed")
}

enum PaymentMethod {
  TUNAI    @map("tunai")
  TRANSFER @map("transfer")
}

enum IncomeCategory {
  MODAL_TAMBAHAN @map("modal_tambahan")
  LAINNYA        @map("lainnya")
}

enum OutcomeCategory {
  BIAYA_PRODUKSI    @map("biaya_produksi")
  BIAYA_OPERASIONAL @map("biaya_operasional")
  PEMASARAN_PROMOSI @map("pemasaran_promosi")
  PEMELIHARAAN      @map("pemeliharaan")
  LAINNYA           @map("lainnya")
}

model User {
  id            String    @id @default(uuid())
  name          String
  username      String
  password      String
  role          Role
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  shifts        Shift[]
  transactions  Transaction[]
  incomes       Income[]
  outcomes      Outcome[]

  @@unique([username])
  @@map("user")
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(100)
  information String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  menus Menu[]
  @@map("category")
}

model Menu {
  id         String   @id @default(uuid())
  name       String   @db.VarChar(100)
  price      Int
  hpp        Int
  stock      Int      @default(0)
  image      String?  @db.VarChar(255)
  categoryId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category           Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  transactionDetails TransactionDetail[]
  @@map("menu")
}

model Shift {
  id                String        @id @default(uuid())
  status            ShiftStatus   @default(OPEN)
  initialCapital    Int
  actualCash        Int?
  cashDifference    Int?
  openingTime       DateTime      @default(now())
  closingTime       DateTime?
  userId            String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user              User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  transactions      Transaction[]
  incomes           Income[]
  outcomes          Outcome[]

  @@map("shift")
}

model Transaction {
  id                 String              @id @default(uuid())
  paymentMethod      PaymentMethod
  totalPrice         Int
  totalPayment       Int
  totalChange        Int                 @default(0)
  userId             String?
  shiftId            String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  user               User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  shift              Shift               @relation(fields: [shiftId], references: [id])
  transactionDetails TransactionDetail[]

  @@map("transaction")
}

model TransactionDetail {
  id            String      @id @default(uuid())
  menuName      String      @db.VarChar(100)
  price         Int
  hpp           Int
  quantity      Int
  subtotal      Int
  isCustom      Boolean     @default(false)
  menuId        String?
  transactionId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  menu          Menu?       @relation(fields: [menuId], references: [id], onDelete: SetNull)
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("transaction_detail")
}

model Income {
  id          String         @id @default(uuid())
  category    IncomeCategory
  total       Int
  information String?        @db.VarChar(255)
  userId      String?
  shiftId     String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  shift       Shift          @relation(fields: [shiftId], references: [id])

  @@map("income")
}

model Outcome {
  id          String          @id @default(uuid())
  category    OutcomeCategory
  total       Int
  information String?         @db.VarChar(255)
  userId      String?
  shiftId     String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  shift       Shift           @relation(fields: [shiftId], references: [id])

  @@map("outcome")
}